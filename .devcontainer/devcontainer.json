{
  "name": "Python Full Throttle",
  "image": "mcr.microsoft.com/devcontainers/miniconda:3",
  "postCreateCommand": "conda env update -n base -f environment.yml && conda clean -afy",
  "postStartCommand": "bash .devcontainer/postStart.sh",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter"]
    }
  },
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": { "label": "JupyterLab" }
  }
}
